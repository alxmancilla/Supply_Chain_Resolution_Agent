MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
GROVE_API_KEY=replace-with-grove-api-key
VOYAGE_API_KEY=replace-with-voyage-api-key

REALM_ID=customer-tenant-001
USER_ID=user-demo
AGENT_ID=supply-chain-resolution-agent

# Provider dispatch (see core/providers/registry.py)
EMBEDDING_PROVIDER=voyage
CHAT_PROVIDER=grove

# Optional cross-provider chat fallback: ordered, comma-separated list of
# chat providers. When set (and >1 entry), `get_chat_provider()` returns a
# `FallbackChatProvider` that advances to the next entry on retryable
# failures (RateLimitError, 5xx, timeouts, connection errors). Each
# fallback emits a `chat_fallback:<name>` marker into the `degraded` state
# channel for one turn. Leave unset to use `CHAT_PROVIDER` alone.
# CHAT_PROVIDERS=grove,openai

# Model name overrides per provider (defaults match the committed
# vector-index dimensions / Grove gateway).
# EMBEDDING_MODEL=voyage-4
# CHAT_MODEL=gpt-5.5

# Cosine thresholds for pre-write dedup in MongoSemanticMemory / MongoEpisodicMemory
SEMANTIC_DEDUP_THRESHOLD=0.92
EPISODIC_DEDUP_THRESHOLD=0.92

# Per-1k-token pricing for the chat provider (used by core/usage.py to
# convert per-turn usage_metadata into a cost_usd estimate). Leave at 0
# to disable cost accounting.
# CHAT_INPUT_PRICE_PER_1K_USD=0.0
# CHAT_OUTPUT_PRICE_PER_1K_USD=0.0

# Opt-in reflection scheduling: when > 0, `save_memory` invokes the
# LLMMemoryReflector against semantic + episodic LTM every N successful
# turns per (realm, user). Default 0 = off; reflection stays a manual
# `tools/reflect.py` job.
# REFLECT_EVERY_N_TURNS=0
# REFLECT_THRESHOLD=0.88

# Hybrid RAG (vector + BM25 with reciprocal-rank fusion) and optional
# cross-encoder reranking. Off by default — vector-only matches the
# pre-P1.2 behavior. Requires the `knowledge_corpus_search` Atlas Search
# index (created by `python -m db.indexes`) when RAG_HYBRID_ENABLED=1.
# RAG_HYBRID_ENABLED=0
# RAG_RERANK_ENABLED=0
# RAG_VECTOR_WEIGHT=1.0
# RAG_BM25_WEIGHT=1.0
# RAG_FUSION_CANDIDATES=20
# RAG_RERANK_MODEL=rerank-2-lite
# RAG_SEARCH_INDEX_NAME=knowledge_corpus_search

# Optional OpenTelemetry export (per-node spans tagged with correlation_id + tenant/user/agent).
# Leave OTEL_ENABLED unset to keep the global tracer as a no-op.
# OTEL_ENABLED=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
